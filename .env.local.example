# .env.local — local developer overrides (copy to .env.local, never commit)
# Values here take priority over .env

# ── Option A: local Docker DB ────────────────────────────────────────────────
# Start the DB container first: docker compose up -d db
DATABASE_URL="postgresql://postgres:<password>@localhost:5432/SendIt-db"

# ── Option B: EC2 DB via SSH tunnel ──────────────────────────────────────────
# Open tunnel first: ssh -L 5432:localhost:5432 ubuntu@<ec2-ip> -N
# Then use the same localhost URL as Option A.

# ── Option C: EC2 DB direct (requires port 5432 open in security group) ──────
# DATABASE_URL="postgresql://postgres:<password>@<ec2-ip>:5432/SendIt-db"
