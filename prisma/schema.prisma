generator client {
  provider     = "prisma-client-js"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      Int                     @id @default(autoincrement())
  email                   String?                 @unique
  phoneNumber             String?                 @unique
  role                    UserRole                @default(CLIENT)
  status                  UserStatus              @default(INACTIVE)
  type                    UserType
  profileCompleted        Boolean                 @default(false)
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  individualProfile       IndividualProfile?
  organizationProfile     OrganizationProfile?
  refreshTokens           RefreshTokens[]
  credentials             UserCredentials?
  resetPasswordTokens     ResetPasswordTokens[]
  shipmentsSent           Shipment[]              @relation("sender")
  shipmentsReceived       Shipment[]              @relation("receiver")
  shipmentsCreated        Shipment[]              @relation("createdBy")
  shipmentStatusHistories ShipmentStatusHistory[] @relation("shipmentStatusCreatedBy")
}

model IndividualProfile {
  userId       Int       @id
  firstName    String
  middleName   String?
  lastName     String
  firstNameLat String?
  lastNameLat  String?
  birthDate    DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OrganizationProfile {
  userId            Int     @id
  companyName       String
  companyNameLat    String?
  edrpou            String  @unique
  taxNumber         String?
  legalAddress      String
  contactPersonName String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserCredentials {
  userId       Int      @id
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshTokens {
  id        Int    @id @default(autoincrement())
  userId    Int
  tokenHash String

  revokedAt DateTime?
  expiresAt DateTime

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
}

model ResetPasswordTokens {
  id     Int @id @default(autoincrement())
  userId Int

  tokenHash       String
  tokenLookupHash String @unique

  usedAt    DateTime?
  expiresAt DateTime

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum UserStatus {
  ACTIVE
  INACTIVE
  DELETED
  BANNED
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  OPERATOR
  COURIER
  CLIENT
}

enum UserType {
  INDIVIDUAL
  ORGANIZATION
}

model Parcel {
  id         Int @id @default(autoincrement())
  shipmentId Int

  weight Decimal
  height Decimal
  width  Decimal
  length Decimal

  declared_value Decimal

  type ParcelType

  origin_address      String
  destination_address String

  updated_at   DateTime      @updatedAt()
  created_at   DateTime      @default(now())
  shipment     Shipment      @relation(fields: [shipmentId], references: [id])
  parcelRoutes ParcelRoute[]
}

model Shipment {
  id Int @id @default(autoincrement())

  senderId   Int
  receiverId Int

  trackingNumber String @unique

  totalPrice     Decimal  @db.Decimal(10, 2)
  insurancePrice Decimal? @db.Decimal(10, 2)

  paymentStatus PaymentStatus @default(PENDING)
  payerType     PayerType

  status ShipmentStatus @default(PENDING)

  estimatedDelivery DateTime?
  deliveredAt       DateTime?

  sender   User @relation("sender", fields: [senderId], references: [id])
  receiver User @relation("receiver", fields: [receiverId], references: [id])

  parcels Parcel[]

  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  shipmentStatusHistories ShipmentStatusHistory[]
  user                    User?                   @relation("createdBy", fields: [userId], references: [id])
  userId                  Int?

  @@index([senderId])
  @@index([receiverId])
  @@index([status])
  @@index([paymentStatus])
}

model ParcelRoute {
  id       Int @id @default(autoincrement())
  parcelId Int

  sequence   Int // порядок у маршруті (1,2,3...)
  arrivedAt  DateTime? // коли прибуло в точку
  departedAt DateTime? // коли вибуло з точки

  status RouteStatus @default(PENDING)

  // warehouseId Int
  // warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  // branchId Int
  // branch   Branch @relation(fields: [branchId], references: [id])

  createdAt DateTime @default(now())

  parcel Parcel @relation(fields: [parcelId], references: [id], onDelete: Cascade)

  @@index([parcelId])
  @@index([sequence])
}

model ShipmentStatusHistory {
  id Int @id @default(autoincrement())

  shipmentId Int
  status     ShipmentStatus

  comment String?

  createdById Int?
  createdBy   User? @relation("shipmentStatusCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@index([status])
}

enum ShipmentStatus {
  PENDING
  SHIPPING
  ARRIVED
  DELIVERED
  CANCELED
  RETEURNED
}

enum ParcelType {
  DOCUMENT
  PACKAGE
  BOX
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELED
}

enum PayerType {
  SENDER
  RECEIVER
  THIRD_PARTY
}

enum RouteStatus {
  PENDING
  IN_TRANSIT
  ARRIVED
  DEPARTED
  SKIPPED
}
